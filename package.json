{
  "name": "spreadsheet",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:server": "pnpm --filter @spreadsheet/server dev",
    "dev:web": "pnpm --filter @spreadsheet/web dev",
    "build": "pnpm --filter @spreadsheet/shared build && pnpm --filter @spreadsheet/server typecheck && pnpm --filter @spreadsheet/web build && pnpm --filter @spreadsheet/server build",
    "typecheck": "pnpm --filter @spreadsheet/shared build && pnpm --filter @spreadsheet/server typecheck && pnpm -r typecheck",
    "lint": "biome check . && pnpm lint:css",
    "lint:fix": "biome check --write . && pnpm lint:css --fix",
    "lint:css": "stylelint 'packages/web/src/**/*.css'",
    "test": "vitest run",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test",
    "verify": "pnpm typecheck && pnpm lint && pnpm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
    "@playwright/test": "^1.59.1",
    "@testcontainers/postgresql": "^11.13.0",
    "husky": "^9.1.7",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "testcontainers": "^11.14.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.27.0"
}

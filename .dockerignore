# Deny-all, then allow only what the Dockerfile needs.
*

# Root config for pnpm install
!pnpm-lock.yaml
!pnpm-workspace.yaml
!package.json

# Workspace packages (source + package.json)
!packages/shared/
!packages/server/
!packages/web/

# Exclude build artifacts and deps inside packages
packages/*/node_modules
packages/*/dist
